
scansso.anonshield.org {
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }
    log {
        output file /var/log/caddy/scansso.anonshield.org-access.log {
            roll_size 100mb
            roll_keep 10
        }
        format json
    }
    reverse_proxy localhost:8911
}
